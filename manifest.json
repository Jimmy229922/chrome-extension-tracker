{
  "manifest_version": 3,
  "name": "Account Copy Tracker (Side Panel)",
  "version": "3.8",
  "description": "إكستنشن لتتبع الحسابات والـ IPs المُنسوخة، مع إشعارات VIP وإدارة ملاحظات. آمن ومفيد للمستخدمين.",
  "author": "Jimmy229922",
  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "sidePanel",
    "offscreen",
    "notifications",
    "tabs",
    "windows",
    "downloads",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://ipwhois.app/*",
    "https://api.telegram.org/",
    "https://docs.google.com/",
    "https://dns.google/*",
    "https://cloudflare-dns.com/*"
  ],
  "side_panel": {
    "default_path": "pages/sidepanel/index.html"
  },
  "action": {},
  "options_page": "pages/options/index.html",
  "icons": {
    "16": "assets/images/icon16.png",
    "48": "assets/images/icon48.png",
    "128": "assets/images/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [ "assets/images/magnifying_glass.png" ],
      "matches": [ "<all_urls>" ]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/csp-guard.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "src/runtime/background.js"
  }
}
